# Copy to .env and adjust. The local Docker Compose stack maps the container's
# 5432 to host port 5433 (see docker-compose.yml) to avoid colliding with a
# local Postgres. sqlx-cli and the app both read .env automatically.
DATABASE_URL=postgres://driftguard:driftguard@localhost:5433/driftguard

# Voyage AI key — embeddings provider for Phase 3 (`select-evals`). Anthropic has
# no first-party embeddings API and recommends Voyage; get a key at voyageai.com.
VOYAGE_API_KEY=

# Anthropic API key — used by the Go LLM sidecar (model under test + judge).
ANTHROPIC_API_KEY=

# Path to the built Go sidecar binary (see `make sidecar`). Defaults to
# `driftguard-llm` on PATH if unset.
DRIFTGUARD_LLM_BIN=./tools/driftguard-llm/driftguard-llm

# Optional model overrides (no rebuild needed — the sidecar/embedder read these).
# Point the model under test at whatever your production app runs.
# DRIFTGUARD_MODEL_UNDER_TEST=claude-sonnet-4-6
# DRIFTGUARD_JUDGE_MODEL=claude-opus-4-8
# VOYAGE_MODEL=voyage-3.5-lite   # dimension is fixed at 1024 (migration-coupled)
