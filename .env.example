# Copy to .env and adjust. The local Docker Compose stack maps the container's
# 5432 to host port 5433 (see docker-compose.yml) to avoid colliding with a
# local Postgres. sqlx-cli and the app both read .env automatically.
DATABASE_URL=postgres://driftguard:driftguard@localhost:5433/driftguard

# Anthropic API key — not used until Phase 3 (embeddings) / Phase 4 (LLM judge).
ANTHROPIC_API_KEY=
